{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arjun-knowledge-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "triggers": {
    "crons": [
      "0 3 * * *"
    ]
  },
  "limits": {
    "cpu_ms": 30000
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "KnowledgeMCP"
      ],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "KnowledgeMCP",
        "name": "MCP_OBJECT"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "09b2d0da76a044489a9c334091d414f6"
    }
  ],
  "observability": {
    "enabled": true
  },
  "workers_dev": true,
  "routes": [
    {
      "pattern": "mcp.dancing-ganesh.com",
      "custom_domain": true
    }
  ]
}
