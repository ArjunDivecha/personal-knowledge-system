{
	"name": "remote-mcp-server-authless",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"deploy:staging": "wrangler deploy --env staging",
		"dev": "wrangler dev",
		"dev:staging": "wrangler dev --env staging",
		"format": "biome format --write",
		"lint:fix": "biome lint --fix",
		"secrets:staging": "wrangler secret bulk .dev.vars.staging --env staging",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"test:worker": "vitest run --no-file-parallelism",
		"test:worker:watch": "vitest --no-file-parallelism",
		"test:dream-live": "node --experimental-strip-types scripts/test-dream-live.ts",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@cloudflare/workers-oauth-provider": "^0.2.2",
		"@upstash/redis": "^1.35.8",
		"@upstash/vector": "^1.2.2",
		"agents": "^0.2.29",
		"openai": "^6.15.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@cloudflare/vitest-pool-workers": "^0.13.5",
		"@types/node": "^25.0.3",
		"typescript": "5.9.3",
		"vitest": "^4.1.2",
		"wrangler": "^4.56.0"
	}
}
